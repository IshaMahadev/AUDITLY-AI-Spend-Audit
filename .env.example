# Copy this file to .env and fill in your values.
# Add all of these to Vercel → Settings → Environment Variables for deployment to work.

# ── Database (Supabase) ─────────────────────────────────────────────────────
# Pooled connection (used by Prisma at runtime via pgbouncer)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# ── AI (optional) ───────────────────────────────────────────────────────────
# Anthropic API key — only needed if AI summary feature is enabled
ANTHROPIC_API_KEY=""

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY="re_..."

# Optional: once you verify a custom domain on Resend, set this to override the
# default onboarding@resend.dev sender (which only delivers to your own account email).
# Example: FROM_EMAIL="Auditly <hello@yourdomain.com>"
FROM_EMAIL=""

# ── App URL ─────────────────────────────────────────────────────────────────
# The public URL of your deployment — used for audit report links in emails and OG tags.
NEXT_PUBLIC_APP_URL="https://ai-spend-audit.vercel.app"
